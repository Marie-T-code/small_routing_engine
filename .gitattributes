# Default: normalize all text files to LF
* text=auto eol=lf

# Binary files: never touch line endings
*.gpkg binary
*.pdf binary
*.ods binary

# Explicit LF rules for critical text types (redundant with the global rule
# above, kept for clarity/intent on sensitive files)
*.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
.env text eol=lf